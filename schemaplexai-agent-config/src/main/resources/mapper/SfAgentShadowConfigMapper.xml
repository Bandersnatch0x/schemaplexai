<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.schemaplexai.agent.config.mapper.SfAgentShadowConfigMapper">

    <resultMap id="BaseResultMap" type="com.schemaplexai.model.entity.agent.SfAgentShadowConfig">
        <id column="id" property="id"/>
        <result column="tenant_id" property="tenantId"/>
        <result column="agent_id" property="agentId"/>
        <result column="feedback_actions_json" property="feedbackActionsJson"/>
        <result column="enabled" property="enabled"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
        <result column="created_by" property="createdBy"/>
        <result column="updated_by" property="updatedBy"/>
        <result column="deleted" property="deleted"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, tenant_id, agent_id, feedback_actions_json, enabled,
        created_at, updated_at, created_by, updated_by, deleted
    </sql>

    <select id="selectByAgentId" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM sf_agent_shadow_config
        WHERE agent_id = #{agentId}
        AND tenant_id = #{tenantId}
        AND deleted = 0
        LIMIT 1
    </select>

</mapper>
