# =============================================================================
# SchemaPlexAI — Environment Variables
# Copy to .env and fill in values before running docker-compose up
# =============================================================================

# --- PostgreSQL ---
POSTGRES_USER=sf_user
POSTGRES_PASSWORD=            # REQUIRED — no default, fail-fast if missing
POSTGRES_DB=schemaplexai

# --- RabbitMQ ---
RABBITMQ_DEFAULT_USER=sf_user
RABBITMQ_DEFAULT_PASS=        # REQUIRED — no default, fail-fast if missing

# --- MinIO ---
MINIO_ROOT_USER=sf_admin
MINIO_ROOT_PASSWORD=          # REQUIRED — no default, fail-fast if missing

# --- Grafana ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=       # REQUIRED — no default, fail-fast if missing

# --- Application DB connection ---
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=                  # REQUIRED — no default, fail-fast if missing
DB_PASSWORD=                  # REQUIRED — no default, fail-fast if missing
DB_SCHEMA=public

# --- Application RabbitMQ connection ---
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=            # REQUIRED — no default, fail-fast if missing
RABBITMQ_PASSWORD=            # REQUIRED — no default, fail-fast if missing

# --- ClickHouse (v1 optional, deferred to v1.1) ---
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_USERNAME=          # REQUIRED if clickhouse.enabled=true
CLICKHOUSE_PASSWORD=          # REQUIRED if clickhouse.enabled=true
CLICKHOUSE_DATABASE=schemaplexai

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- JWT ---
JWT_SECRET=                   # REQUIRED — min 32 bytes, validated at startup
JWT_EXPIRATION=86400000       # 24h in ms

# --- LLM Providers (optional, set at least one) ---
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MAX_RETRIES=3
OPENAI_TIMEOUT=60

ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_MAX_RETRIES=3
ANTHROPIC_TIMEOUT=60

AGENT_DEFAULT_MODEL=
